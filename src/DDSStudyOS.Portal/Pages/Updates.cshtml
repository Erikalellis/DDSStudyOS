@page
@{
    ViewData["Title"] = "DDS Update Tracker";
}

<section class="page-shell update-tracker-page" data-tracker-api-url="@Url.Content("~/api/updates/tracker")">
    <span class="eyebrow">DDS Update Tracker</span>
    <h1>Atualizacoes centralizadas do DDS StudyOS</h1>
    <p class="lead">
        Timeline unica para acompanhar stable e beta sem depender de navegar no GitHub.
        Aqui voce ve status, downloads, SHA256, changelog resumido e visao publica do DDS-DLC.
    </p>

    <div id="trackerLoading" class="tracker-state">Carregando tracker...</div>
    <div id="trackerError" class="tracker-state tracker-state-error" hidden>
        Falha ao carregar o tracker no momento. Tente novamente em alguns instantes.
    </div>

    <div id="trackerContent" hidden>
        <section class="tracker-section">
            <h2>Timeline de versoes (stable/beta)</h2>
            <div id="timelineGrid" class="timeline"></div>
        </section>

        <section class="tracker-section">
            <h2>Status de cada release</h2>
            <div id="channelGrid" class="timeline"></div>
        </section>

        <section class="tracker-section">
            <h2>DDS-DLC (resumo publico)</h2>
            <article id="dlcCard" class="timeline-card"></article>
        </section>

        <section class="tracker-section">
            <h2>Historico de releases</h2>
            <div id="releaseGrid" class="timeline"></div>
        </section>
    </div>

    <a class="back-link" href="/">Voltar para a home publica</a>
</section>

@section Scripts {
<script src="~/js/update-tracker.js" asp-append-version="true"></script>
}

<style>
    .page-shell {
        max-width: 1040px;
        margin: 0 auto;
        padding: 36px 24px 48px;
    }
    .eyebrow {
        display: inline-block;
        margin-bottom: 12px;
        color: #9eeeff;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }
    h1 {
        margin: 0 0 12px;
        color: var(--text);
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 1.05;
    }
    .lead, .timeline-card p {
        color: var(--muted);
        line-height: 1.7;
    }
    .tracker-state {
        margin-top: 22px;
        padding: 14px 18px;
        border-radius: 16px;
        border: 1px solid var(--line);
        background: rgba(10, 19, 45, 0.82);
        color: var(--text);
    }
    .tracker-state-error {
        border-color: rgba(255, 133, 133, 0.45);
        background: rgba(70, 18, 18, 0.45);
    }
    .tracker-section {
        margin-top: 24px;
    }
    .tracker-section h2 {
        margin-bottom: 12px;
        color: var(--text);
    }
    .timeline {
        display: grid;
        gap: 18px;
        margin-top: 14px;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
    .timeline-card {
        border: 1px solid var(--line);
        border-radius: 24px;
        background: linear-gradient(165deg, rgba(13, 23, 52, 0.92), rgba(9, 17, 40, 0.92));
        padding: 22px;
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
    }
    .tracker-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
    }
    .timeline-card strong {
        color: #f6f8ff;
        font-size: 1.08rem;
    }
    .status-pill {
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 0.76rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }
    .status-pill.is-published {
        background: rgba(68, 240, 193, 0.18);
        color: #d2fff1;
    }
    .status-pill.is-test {
        background: rgba(246, 194, 95, 0.2);
        color: #ffe4ab;
    }
    .status-pill.is-hotfix {
        background: rgba(255, 122, 122, 0.2);
        color: #ffcdcd;
    }
    .tracker-list-block {
        margin-top: 20px;
    }
    .tracker-list-block strong {
        display: block;
        margin-bottom: 8px;
        color: #dce7ff;
    }
    .tracker-list-block ul {
        margin: 0;
        padding-left: 18px;
        color: var(--muted);
        line-height: 1.65;
    }
    .timeline-card a, .back-link {
        color: #b8ddff;
        font-weight: 700;
        text-decoration: none;
    }
    .tracker-code {
        display: inline-block;
        max-width: 100%;
        overflow-wrap: anywhere;
    }
    .back-link {
        display: inline-flex;
        margin-top: 24px;
    }
</style>

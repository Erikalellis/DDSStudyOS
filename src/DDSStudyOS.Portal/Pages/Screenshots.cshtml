@page
@{
    ViewData["Title"] = "Screenshots";
}

<section class="page-shell">
    <nav class="portal-nav">
        <a href="/">Home</a>
        <a href="/Downloads">Downloads</a>
        <a href="/Updates">Updates</a>
        <a href="/Screenshots">Screenshots</a>
        <a href="/Roadmap">Roadmap</a>
        <a href="/Support">Support</a>
        <a href="/StudyPass">DDS Study Pass</a>
    </nav>

    <span class="eyebrow">Screenshots</span>
    <h1>Visao publica do DDS StudyOS</h1>
    <p class="lead">
        Esta area concentra telas e artes oficiais do aplicativo para referencia publica.
        O foco atual do site e institucional: produto, releases, changelog e suporte.
    </p>

    <div class="gallery">
        <article class="shot-card">
            <img src="~/images/SplashBackdrop.png" alt="Splash oficial do DDS StudyOS" />
            <strong>Splash oficial</strong>
            <p>Tela de abertura usada na camada visual do app.</p>
        </article>
        <article class="shot-card">
            <img src="~/images/SplashBackground.png" alt="Background oficial do DDS StudyOS" />
            <strong>Background institucional</strong>
            <p>Arte base para onboarding, paines e comunicacao visual.</p>
        </article>
        <article class="shot-card">
            <img src="~/images/DDSStudyOS-Icon-Source.png" alt="Icone oficial do DDS StudyOS" />
            <strong>Icone da aplicacao</strong>
            <p>Marca principal usada nos instaladores e na identidade publica.</p>
        </article>
    </div>

    <div class="secondary-panel">
        <strong>Uso desta pagina</strong>
        <p>
            Esta galeria e dedicada a visao do produto.
            Novas telas do app serao adicionadas aqui conforme a interface evoluir.
        </p>
    </div>
</section>

<style>
    .page-shell {
        max-width: 1040px;
        margin: 0 auto;
        padding: 36px 24px 48px;
    }
    .portal-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 16px;
    }
    .portal-nav a {
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid rgba(164, 180, 215, 0.16);
        background: rgba(8, 14, 30, 0.74);
        color: #dce6ff;
        font-size: 0.94rem;
        text-decoration: none;
    }
    .eyebrow {
        display: inline-block;
        margin-bottom: 12px;
        color: #7c5cff;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }
    h1 {
        margin: 0 0 12px;
        color: #eef2ff;
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 1.05;
    }
    .lead, .shot-card p, .secondary-panel p {
        color: #c9d4ea;
        line-height: 1.7;
    }
    .gallery {
        display: grid;
        gap: 18px;
        margin-top: 28px;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
    .shot-card, .secondary-panel {
        border: 1px solid rgba(164, 180, 215, 0.16);
        border-radius: 24px;
        background: rgba(8, 14, 30, 0.84);
        padding: 22px;
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
    }
    .shot-card img {
        width: 100%;
        border-radius: 14px;
        margin-bottom: 12px;
        border: 1px solid rgba(164, 180, 215, 0.18);
        background: rgba(8, 14, 30, 0.6);
        object-fit: cover;
        max-height: 220px;
    }
    .shot-card strong, .secondary-panel strong {
        display: block;
        margin-bottom: 10px;
        color: #f6f8ff;
        font-size: 1.08rem;
    }
    .secondary-panel {
        margin-top: 20px;
    }
</style>

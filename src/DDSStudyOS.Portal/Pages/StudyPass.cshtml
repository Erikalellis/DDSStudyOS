@page
@{
    ViewData["Title"] = "DDS Study Pass";
}

<section class="page-shell">
    <span class="eyebrow">DDS Study Pass</span>
    <h1>Visao de produto e comunicacao publica</h1>
    <p class="lead">
        O DDS Study Pass funciona como area institucional para comunicar evolucao do DDS StudyOS.
        Nesta fase, ele concentra roadmap, status e atualizacoes do ecossistema.
    </p>

    <div class="info-grid">
        <article class="panel">
            <h2>O que entra agora</h2>
            <ul>
                <li>novidades do app</li>
                <li>screenshots e demonstracoes</li>
                <li>roadmap publico</li>
                <li>downloads e changelog</li>
                <li>status operacional da plataforma</li>
            </ul>
        </article>

        <article class="panel">
            <h2>O que fica para depois</h2>
            <ul>
                <li>servicos avancados de conta</li>
                <li>expansao de integracoes externas</li>
                <li>camada de automacoes inteligentes</li>
                <li>mais recursos de produtividade</li>
                <li>ownership, login e sincronizacao</li>
            </ul>
        </article>
    </div>

    <div class="timeline">
        <article class="timeline-card">
            <strong>Portal publico agora</strong>
            <p>Posicionamento de produto, informacoes e comunicacao para usuarios finais.</p>
        </article>
        <article class="timeline-card">
            <strong>Plataforma mais completa</strong>
            <p>Consolidar experiencia do app, qualidade de release e camada publica institucional.</p>
        </article>
        <article class="timeline-card">
            <strong>Integracao futura app + servicos</strong>
            <p>Evoluir a conexao entre app, portal e infraestrutura de forma segura e escalavel.</p>
        </article>
    </div>

    <a class="back-link" href="/">Voltar para a home publica</a>
</section>

<style>
    .page-shell {
        max-width: 1040px;
        margin: 0 auto;
        padding: 36px 24px 48px;
    }

    .eyebrow {
        display: inline-block;
        margin-bottom: 12px;
        color: #7c5cff;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    h1 {
        margin: 0 0 12px;
        color: #eef2ff;
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 1.05;
    }

    .lead,
    .panel li,
    .timeline-card p {
        color: #c9d4ea;
        line-height: 1.7;
    }

    .info-grid,
    .timeline {
        display: grid;
        gap: 18px;
        margin-top: 28px;
    }

    .info-grid {
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }

    .timeline {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .panel,
    .timeline-card {
        border: 1px solid rgba(164, 180, 215, 0.16);
        border-radius: 24px;
        background: rgba(8, 14, 30, 0.84);
        padding: 22px;
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
    }

    .panel h2,
    .timeline-card strong {
        display: block;
        margin: 0 0 10px;
        color: #f6f8ff;
        font-size: 1.08rem;
    }

    .panel ul {
        margin: 0;
        padding-left: 18px;
    }

    .back-link {
        display: inline-flex;
        margin-top: 24px;
        color: #8ea6ff;
        font-weight: 700;
        text-decoration: none;
    }
</style>

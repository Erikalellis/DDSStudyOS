<Page
    x:Class="DDSStudyOS.App.Pages.StorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12,10"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <SymbolIcon Symbol="Shop" />
                    <TextBlock Text="Loja DDS"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="StoreStatusText"
                               Text="Conectando..."
                               Opacity="0.75"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Abrir Loja" Click="OpenStore_Click" />
                    <Button Content="Recarregar" Click="Reload_Click" />
                    <Button Content="Abrir no Navegador Externo"
                            Click="OpenExternal_Click"
                            Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <controls:WebView2 x:Name="StoreWebView" Grid.Row="1" />
    </Grid>
</Page>

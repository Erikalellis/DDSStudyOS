<Page
    x:Class="DDSStudyOS.App.Pages.OfflinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid Padding="24" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Cursos Offline" Style="{StaticResource TitleTextBlockStyle}"/>
                    <Border x:Name="CountBadge"
                            Background="#331D4ED8" BorderBrush="#661D4ED8" BorderThickness="1"
                            CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                        <TextBlock x:Name="CountBadgeText" Text="0" FontSize="12" Foreground="#FF8EC8FF"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Cursos salvos para acesso sem internet." Style="{StaticResource BodyTextBlockStyle}" Opacity="0.82"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock x:Name="CacheSizeText" VerticalAlignment="Center" Opacity="0.6" FontSize="12"/>
                <Button x:Name="ClearAllButton" Content="Limpar tudo" Click="ClearAll_Click"
                        IsEnabled="False"/>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Empty state -->
            <StackPanel x:Name="EmptyStatePanel" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="16" Visibility="Collapsed">
                <FontIcon Glyph="&#xE753;" FontSize="48" Opacity="0.4"/>
                <TextBlock Text="Nenhum curso salvo offline ainda."
                           Style="{StaticResource SubtitleTextBlockStyle}" Opacity="0.6"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Acesse um curso no Navegador e clique em 'Salvar offline' para disponibilizá-lo sem internet."
                           Style="{StaticResource BodyTextBlockStyle}" Opacity="0.5"
                           HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="420"/>
                <Button Content="Ir para o Navegador" Click="GoToBrowser_Click"
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Course list — cards adicionados via code-behind -->
            <ScrollViewer x:Name="ListScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="CoursesStackPanel" Spacing="12" Margin="0,0,0,16"/>
            </ScrollViewer>

            <!-- Loading -->
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="40" Height="40"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>
